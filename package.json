{
  "name": "@incremental-code/last-ui",
  "version": "0.0.1",
  "description": "A small TypeScript component library for the last-act / last-router stack.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "default": "./dist/tokens.js"
    }
  },
  "files": [
    "dist",
    "src",
    "readme.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@incremental-code/last-act": "^0.0.1"
  },
  "peerDependencies": {
    "@floating-ui/dom": "^1.6.0"
  },
  "devDependencies": {
    "@floating-ui/dom": "^1.6.0",
    "typescript": "^5.6.3"
  }
}
